from sympy import *
from sympy.parsing.sympy_parser import (
    parse_expr, standard_transformations,
    implicit_multiplication_application
)

# Parser setup
transformations = standard_transformations + (implicit_multiplication_application,)

x = symbols('x')

# ---------------------------
# 🔒 Helpers
# ---------------------------
def preprocess(expr):
    expr = expr.replace(" ", "")
    expr = expr.replace("^", "**")
    expr = expr.replace("√", "sqrt")
    return expr

def split_args(text):
    parts, bracket, current = [], 0, ""
    for ch in text:
        if ch == "," and bracket == 0:
            parts.append(current.strip())
            current = ""
        else:
            if ch in "([{": bracket += 1
            elif ch in ")]}": bracket -= 1
            current += ch
    if current:
        parts.append(current.strip())
    return parts

def to_int(val):
    v = sympify(val)
    if not v.is_integer:
        raise ValueError("Must be integer")
    return int(v)

# ---------------------------
# 📘 HELP MENU
# ---------------------------
def show_help():
    print("""
